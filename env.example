# Copy to .env and fill in:  cp env.example .env

# --- App ---
APP_ENV=development
# Bind 127.0.0.1 locally; 0.0.0.0 for containers/Railway
HOST=127.0.0.1
PORT=8002

# --- Database (async SQLAlchemy) ---
# Postgres in prod; SQLite is fine for local dev / tests.
DATABASE_URL=postgresql+asyncpg://yoav@localhost:5432/cutebot
# DATABASE_URL=sqlite+aiosqlite:///./cutebot.db

# --- AI (LiteLLM; Claude by default) ---
# One-line model switch. Anthropic format: anthropic/<model-id>.
# Default is a cost-effective high-quality copywriter; swap to
# anthropic/claude-opus-4-8 for the most capable model.
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-6
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=        # only if you switch DEFAULT_LLM_MODEL to an OpenAI model

# --- LLM reliability ---
# Timeout per model call in seconds. LiteLLM retries on 429/5xx/timeout automatically.
LLM_TIMEOUT_S=60
# Retries LiteLLM attempts on transient errors before raising.
LLM_NUM_RETRIES=2
# Max tokens per completion call (caps cost; 2000 is generous for captions).
LLM_MAX_TOKENS=2000

# --- Telegram review channel ---
TELEGRAM_BOT_TOKEN=
# Your personal chat id (where suggestions are DM'd). Get it from @userinfobot.
TELEGRAM_CHAT_ID=
# Public HTTPS base URL for webhook mode (e.g. an ngrok/Railway URL).
# Leave empty to use long-polling in local dev.
TELEGRAM_WEBHOOK_BASE=

# --- Pipeline tuning ---
# How many suggestions to generate per batch.
BATCH_SIZE=5
# Cron for batch generation (default: 9am daily). APScheduler cron syntax.
GENERATION_CRON=0 9 * * *
# Comma-separated daily posting slots in HH:MM (local) the queue drains into.
POSTING_SLOTS=12:00,18:00
# Path to the brand guidelines file (see brand.example.yaml).
BRAND_FILE=brand.yaml

# --- Image-first generation (stock library + bilingual captioning) ---
# Directory holding your stock images (drop your images into stock/ — not committed).
STOCK_IMAGES_DIR=stock
# Primary caption language (written first, e.g. in Telegram review + publish).
PRIMARY_LANGUAGE=he
# Comma-separated secondary languages, written after the primary.
SECONDARY_LANGUAGES=en
# Cute AI-disclosure line appended in code to every post (review + publish).
POST_DISCLAIMER=🤖 מאת CuteBot · by CuteBot

# --- Publishers (stubs in v1; leave blank to no-op) ---
INSTAGRAM_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
